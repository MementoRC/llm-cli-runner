# Debian-based Test Environment (glibc compatible)
FROM python:3.13-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    bash \
    build-essential \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install pixi
RUN curl -fsSL https://pixi.sh/install.sh | bash
ENV PATH="/root/.pixi/bin:$PATH"

# Set environment variables for compatibility
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH="/workspace/src"

# Set working directory
WORKDIR /workspace

# Copy project files
COPY . .

# Test pixi installation and install dependencies
RUN pixi --version || (echo "Pixi installation failed" && exit 1)

# Pre-install quality environment - should work seamlessly with glibc
RUN pixi install -e quality || (echo "Failed to install quality environment" && exit 1)

# Install dependencies and run full test suite
CMD ["sh", "-c", "set -e && echo 'Debian/glibc test starting...' && pixi --version && echo 'Installing quality environment...' && pixi install -e quality && echo 'Running full test suite...' && pixi run -e quality test"]
