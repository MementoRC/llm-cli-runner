# Alpine 3.18 Test Environment
FROM alpine:3.18

# Install system dependencies including additional libraries for Python packages
RUN apk add --no-cache \
    curl \
    bash \
    build-base \
    git \
    python3 \
    python3-dev \
    py3-pip \
    linux-headers \
    libffi-dev \
    openssl-dev \
    musl-dev \
    gcc \
    g++

# Install pixi
RUN curl -fsSL https://pixi.sh/install.sh | bash
ENV PATH="/root/.pixi/bin:$PATH"

# Set working directory
WORKDIR /workspace

# Copy project files
COPY . .

# Test pixi installation and install dependencies with better error handling
RUN pixi --version || (echo "Pixi installation failed" && exit 1)

# Install dependencies and run tests with simplified approach
CMD ["sh", "-c", "set -e && echo 'Alpine test starting...' && pixi --version && echo 'Installing minimal environment...' && pixi install -e ci-minimal && echo 'Running basic tests...' && pixi run -e ci-minimal test"]
