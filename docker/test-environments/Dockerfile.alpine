# Alpine 3.18 Test Environment
FROM alpine:3.18

# Install system dependencies including additional libraries for Python packages
RUN apk add --no-cache \
    curl \
    bash \
    build-base \
    git \
    python3 \
    python3-dev \
    py3-pip \
    linux-headers \
    libffi-dev \
    openssl-dev \
    musl-dev \
    gcc \
    g++ \
    gcompat \
    libc6-compat \
    libstdc++ \
    ca-certificates

# Install pixi
RUN curl -fsSL https://pixi.sh/install.sh | bash
ENV PATH="/root/.pixi/bin:$PATH"

# Set environment variables for Alpine compatibility
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH="/workspace/src"
ENV RUSTFLAGS="-C target-feature=-crt-static"
ENV CONDA_OVERRIDE_GLIBC=2.28

# Set working directory
WORKDIR /workspace

# Copy project files
COPY . .

# Test pixi installation and install dependencies with better error handling
RUN pixi --version || (echo "Pixi installation failed" && exit 1)

# Pre-install quality environment to catch issues early
RUN CONDA_OVERRIDE_GLIBC=2.28 pixi install -e quality || (echo "Failed to install quality environment" && exit 1)

# Install dependencies and run tests aligned with CI workflow
CMD ["sh", "-c", "set -e && echo 'Alpine test starting...' && pixi --version && echo 'Installing quality environment...' && pixi install -e quality && echo 'Running basic tests...' && pixi run -e quality pytest tests/ --tb=short -x"]
